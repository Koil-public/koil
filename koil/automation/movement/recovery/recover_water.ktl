version: 1
kind: task_template
id: template.movement_recovery_recover_water
template_id: movement/recovery/recover_water
semantic_operation: sem.task.swim
params: []
metadata:
  semantic_operations: [sem.task.swim]
  target_kinds: [location]
  required_params: []
  optional_params: []
  tags: [movement, recovery, water]
steps:
