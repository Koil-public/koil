version: 1
kind: task_template
id: template.movement_interact_move_to_open_container
template_id: movement/interact/move_to_open_container
semantic_operation: sem.task.open_target
params: [target.id, target.selector, radius, stop.distance]
metadata:
  semantic_operations: [sem.task.open_target]
  target_kinds: [block]
  required_params: [target.id]
  optional_params: [target.selector, radius, stop.distance]
  tags: [movement, interact, container]
steps:
  - type: delegate
    delegate: movement/navigation/move_to_interactable.ktl target.id=${target.id} target.selector=${target.selector} radius=${radius} stop.distance=${stop.distance}
  - type: run_primitive
    action: cap.interaction.open_target
    params: {}
  - type: return
    label: done
