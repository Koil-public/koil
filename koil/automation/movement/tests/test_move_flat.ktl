version: 1
kind: task_template
id: template.movement_tests_test_move_flat
template_id: movement/tests/test_move_flat
semantic_operation: sem.task.move_to_target
params: [target.x, target.z]
metadata:
  semantic_operations: [sem.task.move_to_target]
  target_kinds: [location]
  required_params: [target.x, target.z]
  optional_params: []
  tags: [movement, test]
steps:
  - type: delegate
    delegate: movement/navigation/move_to_position.ktl target.x=${target.x} target.z=${target.z} stop.distance=0.8 movement.allow_parkour=false movement.allow_swim=false movement.allow_sprint=false
  - type: run_primitive
    action: cap.report.status_line
    params:
      message: movement test flat complete
  - type: return
    label: done
