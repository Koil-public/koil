version: 1
kind: task_template
id: template.movement_tests_test_maze_navigation
template_id: movement/tests/test_maze_navigation
semantic_operation: sem.task.move_to_target
params: [target.x, target.y, target.z]
metadata:
  semantic_operations: [sem.task.move_to_target]
  target_kinds: [location]
  required_params: [target.x, target.z]
  optional_params: [target.y]
  tags: [movement, test, maze, navigation]
steps:
  - type: delegate
    delegate: movement/navigation/move_to_position.ktl target.x=${target.x} target.y=${target.y} target.z=${target.z} stop.distance=0.9 movement.policy=human_smart movement.persistent=true movement.allow_parkour=true movement.allow_swim=true movement.allow_sprint=true movement.allow_break_blocks=false movement.allow_place_blocks=false movement.allow_combat_clear=false
  - type: return
    label: done
