version: 1
kind: task_template
id: template.movement_tests_test_sprint_jump_gap
template_id: movement/tests/test_sprint_jump_gap
semantic_operation: sem.task.move_to_target
params: [target.x, target.y, target.z]
metadata:
  semantic_operations: [sem.task.move_to_target]
  target_kinds: [location]
  required_params: [target.x, target.y, target.z]
  optional_params: []
  tags: [movement, test, parkour]
steps:
  - type: delegate
    delegate: movement/parkour/parkour_sprint_jump.ktl target.x=${target.x} target.y=${target.y} target.z=${target.z} stop.distance=0.7
  - type: run_primitive
    action: cap.report.status_line
    params:
      message: movement test sprint jump gap complete
  - type: return
    label: done
