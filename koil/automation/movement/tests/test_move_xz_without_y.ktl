version: 1
kind: task_template
id: template.movement_tests_test_move_xz_without_y
template_id: movement/tests/test_move_xz_without_y
semantic_operation: sem.task.move_to_target
params: [target.x, target.z]
metadata:
  semantic_operations: [sem.task.move_to_target]
  target_kinds: [location]
  required_params: [target.x, target.z]
  optional_params: []
  tags: [movement, test]
steps:
  - type: delegate
    delegate: movement/resolve/resolve_xz_to_standable_y.ktl target.x=${target.x} target.z=${target.z} stop.distance=0.8 movement.allow_swim=false
  - type: delegate
    delegate: movement/navigation/follow_path.ktl stop.distance=0.8 movement.allow_parkour=true movement.allow_swim=false movement.allow_sprint=true
  - type: run_primitive
    action: cap.report.status_line
    params:
      message: movement test xz y-resolution complete
  - type: return
    label: done
