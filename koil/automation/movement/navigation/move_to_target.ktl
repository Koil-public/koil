version: 1
kind: task_template
id: template.movement_navigation_move_to_target
template_id: movement/navigation/move_to_target
semantic_operation: sem.task.move_to_target
params: [target.id, target.kind, target.selector, target.x, target.y, target.z, radius, stop.distance, movement.policy, movement.persistent, movement.precise, movement.precision.distance, movement.precision.slow_distance, movement.allow_parkour, movement.allow_swim, movement.allow_sprint, movement.allow_break_blocks, movement.allow_place_blocks, movement.allow_combat_clear]
metadata:
  semantic_operations: [sem.task.move_to_target]
  target_kinds: [entity, player, block, item, location]
  required_params: []
  optional_params: [target.id, target.kind, target.selector, target.x, target.y, target.z, radius, stop.distance, movement.policy, movement.persistent, movement.precise, movement.precision.distance, movement.precision.slow_distance, movement.allow_parkour, movement.allow_swim, movement.allow_sprint, movement.allow_break_blocks, movement.allow_place_blocks, movement.allow_combat_clear]
  tags: [movement, navigation, smart, human]
steps:
  - type: delegate
    delegate: movement/core/movement_context.ktl
  - type: delegate
    delegate: movement/resolve/resolve_target.ktl target.id=${target.id} target.kind=${target.kind} target.selector=${target.selector} target.x=${target.x} target.y=${target.y} target.z=${target.z} radius=${radius} stop.distance=${stop.distance}
  - type: delegate
    delegate: movement/navigation/follow_path.ktl stop.distance=${stop.distance} movement.precise=${movement.precise} movement.precision.distance=${movement.precision.distance} movement.precision.slow_distance=${movement.precision.slow_distance} movement.policy=${movement.policy} movement.persistent=${movement.persistent} movement.allow_parkour=${movement.allow_parkour} movement.allow_swim=${movement.allow_swim} movement.allow_sprint=${movement.allow_sprint} movement.allow_break_blocks=${movement.allow_break_blocks} movement.allow_place_blocks=${movement.allow_place_blocks} movement.allow_combat_clear=${movement.allow_combat_clear}
  - type: run_primitive
    action: cap.path.verify_target_arrival
    params:
      stop.distance: ${stop.distance}
  - type: delegate
    delegate: movement/core/movement_stop.ktl
  - type: return
    label: done
