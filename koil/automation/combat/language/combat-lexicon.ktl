version: 1
kind: lexicon
id: lexicon.combat_phrases
entries:
  - id: action.combat.kill
    type: action
    phrases: [kill, slay, defeat]
    maps_to: sem.task.kill_target
    defaults:
      target.selector: nearest
      count.value: 1
      state.counter: 0
      radius: 32
      stop.distance: 2.8
      attack.range: 3.4
      movement.allow_parkour: true
      movement.allow_sprint: true

