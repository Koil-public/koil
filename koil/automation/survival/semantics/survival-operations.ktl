version: 1
kind: semantic_operation_pack
id: semantics.survival
operations:
  - id: sem.task.consume_item
    intent: consume
    target_kinds: [item]
    preferred_templates: [survival/core/eat_item_until_count]

  - id: sem.task.use_item
    intent: use_item
    target_kinds: [item]
    preferred_templates: [survival/core/use_selected_item]

  - id: sem.task.survival_check
    intent: survival_check
    target_kinds: []
    preferred_templates: [survival/core/survival_gate]

