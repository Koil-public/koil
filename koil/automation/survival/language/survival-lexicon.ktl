version: 1
kind: lexicon
id: lexicon.survival_phrases
entries:
  - id: action.survival.eat
    type: action
    phrases: [eat, consume]
    maps_to: sem.task.consume_item
    defaults:
      count.value: 1
      state.counter: 0

  - id: action.survival.use_item
    type: action
    phrases: [use item, use held item]
    maps_to: sem.task.use_item
    defaults:
      hand.id: main_hand

