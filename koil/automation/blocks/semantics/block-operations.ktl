version: 1
kind: semantic_operation_pack
id: semantics.blocks
operations:
  - id: sem.task.mine_block_count
    intent: mine
    target_kinds: [block]
    preferred_templates: [blocks/core/mine_block_until_count]

  - id: sem.task.place_item_on_target
    intent: place
    target_kinds: [block]
    preferred_templates: [blocks/core/place_item_on_block_target]

